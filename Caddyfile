ronit.ai {
    header {
        # CORS Headers
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
        Access-Control-Allow-Headers "Content-Type, Authorization, Upgrade, Connection, X-Requested-With, Accept"
        Access-Control-Max-Age "86400"

        # CRITICAL FIX: Allow microphone access so Ronit AI can hear users
        Permissions-Policy "microphone=*, camera=*"
    }

    reverse_proxy localhost:5000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
}





studio.nbmedia.co.in {
    reverse_proxy localhost:3005 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Real-IP {remote_host}
        flush_interval -1
    }

    # Enable compression
    encode gzip zstd

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Cache static assets
    @static {
        path /_next/static/* /favicon.ico /images/*
    }
    header @static Cache-Control "public, max-age=31536000, immutable"
}


diet.dietitianamisha.com {
    encode gzip

    # Recipe image upload limit
    request_body {
        max_size 12MB
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # API → FastAPI uvicorn
    handle /api/* {
        reverse_proxy localhost:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Frontend (CRA dev server / serve build)
    handle {
        reverse_proxy localhost:3007 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}

