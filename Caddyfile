ga.nbmedia.co.in {
    # Global settings for video streaming
    # Note: Large uploads handled by extended timeouts in reverse_proxy
    
    # Compress text-based content (Caddy automatically skips compressed formats like videos)
    encode gzip

    # HLS Streaming and Static Video Files Handler
    handle_path /history_static/* {
        root * /root/NB_Projects/V2/GAModel/history
        
        # Define matchers for different file types
        @hls_manifest path *.m3u8
        @hls_segments path *.ts *.m4s
        @video_files path *.mp4 *.webm *.mov *.avi
        
        # Handle OPTIONS preflight requests
        @options method OPTIONS
        handle @options {
            header Access-Control-Allow-Origin "*"
            header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
            header Access-Control-Allow-Headers "Range, Content-Type, Accept-Encoding"
            header Access-Control-Max-Age "86400"
            respond 204
        }

        # Common headers for all video content
        header {
            # CORS headers for cross-origin video loading
            Access-Control-Allow-Origin "*"
            Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
            Access-Control-Allow-Headers "Range, Content-Type, Accept-Encoding"
            Access-Control-Expose-Headers "Content-Length, Content-Range, Content-Type"
            Access-Control-Max-Age "86400"
            
            # Critical for seeking and buffering
            Accept-Ranges bytes
            
            # Prevent video transcoding/optimization by proxies
            X-Content-Type-Options "nosniff"
        }
        
        # HLS manifests - short cache (they can change)
        header @hls_manifest {
            Cache-Control "public, max-age=10, no-transform"
            Content-Type "application/vnd.apple.mpegurl"
        }
        
        # HLS segments - medium cache (immutable once created)
        header @hls_segments {
            Cache-Control "public, max-age=3600, immutable, no-transform"
        }
        
        # Video files - long cache (permanent content)
        header @video_files {
            Cache-Control "public, max-age=604800, immutable, no-transform"
        }
        
        # Enable file server
        file_server
    }

    # API and main app handler
    handle {
        # Extended timeouts for video uploads and processing
        reverse_proxy localhost:3000 {
            # Forward real client information
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            
            # Timeouts for long video operations and uploads
            transport http {
                read_timeout 7200s
                write_timeout 7200s
                dial_timeout 30s
                response_header_timeout 300s
            }
        }
    }
}



