  userId    Int
  managerId Int

  viewer  User @relation("ReportViewer", fields: [userId], references: [id], onDelete: Cascade)
  manager User @relation("ReportViewable", fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([userId, managerId])
  @@index([userId])
  @@index([managerId])
}

model ChannelBaseline {
