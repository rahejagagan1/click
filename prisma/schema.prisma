  overallScore Decimal? @db.Decimal(5, 2)
  comments     String?  @db.Text
  isDraft      Boolean  @default(false) // true = saved as draft, false = final submission
  submittedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

