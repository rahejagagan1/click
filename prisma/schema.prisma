/// Team members rate their manager (used in CM Pillar 5).
/// Each team member submits one rating per period for their manager.
/// The average across all team members is 50% of the combined pillar.
model TeamManagerRating {
  id           Int      @id @default(autoincrement())
  teamMemberId Int // who submitted the rating (team member)
  managerId    Int // who was rated (the CM/PM)
  period       String // "2026-03"
  periodType   String   @default("monthly")
  ratingsJson  Json     @db.JsonB // { "team_q1": 4, "team_q2": 3, ... }
  overallScore Decimal? @db.Decimal(5, 2)
  comments     String?  @db.Text
  isAnonymous  Boolean  @default(true)
  submittedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teamMember User @relation("TeamMemberRater", fields: [teamMemberId], references: [id])
  manager    User @relation("ManagerRated", fields: [managerId], references: [id])

  @@unique([teamMemberId, managerId, period, periodType])
  @@index([managerId, period])
  @@index([teamMemberId])
}

model RatingConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique // e.g. "writer_weights", "writer_quality_brackets", "yt_views_brackets"
  value     Json     @db.JsonB
  updatedAt DateTime @updatedAt
}

model WeeklyReport {
  id             Int      @id @default(autoincrement())
  managerId      Int
  week           Int // 1..N per month (Mon–Sun weeks; N usually 4–5)
  month          Int // 0–11
  year           Int
  // Named columns replacing dataJson blob
  writerRows     Json?    @db.JsonB // Section A1: Writer output rows
  editorRows     Json?    @db.JsonB // Section A2: Editor output rows
  researcherRows Json?    @db.JsonB // Section A3: Researcher performance rows
  overviewRows   Json?    @db.JsonB // Section B: Quick overview rows
  viewsRows      Json?    @db.JsonB // Section D: Views and Changes rows (Andrew)
  shortsRows     Json?    @db.JsonB // Section E: Views and Changes (YT Shorts) rows (Andrew)
  dataJson       Json?    @db.JsonB // Legacy fallback (kept for old records)
  /// Which report template this row belongs to: production|researcher|qa|hr.
  /// Backfilled from getManagerReportFormat for legacy rows; set explicitly on
  /// new reports. Part of the row identity going forward (multi-template).
  reportTemplate String?
  /// Frozen team roster at submit/lock time so historical reports
  /// keep showing who was on the team that week even if those users
  /// later move to a different manager. Shape:
  ///   Array<{ id: number, name: string, role: string, orgLevel: string | null, profilePictureUrl: string | null }>
  /// Null on legacy rows submitted before this column existed — those
  /// fall back to the live `manager.teamMembers` query.
  teamSnapshot   Json?    @db.JsonB
  isLocked       Boolean  @default(true)
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manager User @relation("ManagerWeeklyReports", fields: [managerId], references: [id])

  @@unique([managerId, week, month, year])
  // Template-inclusive identity (Phase A: added alongside the legacy key above).
  @@unique([managerId, reportTemplate, week, month, year])
  @@index([managerId])
  @@index([year, month, week]) // covers ORDER BY year desc, month desc, week desc
}

model MonthlyReport {
  id             Int      @id @default(autoincrement())
  managerId      Int
  month          Int // 0–11
  year           Int
  /// production|researcher|qa|hr — see WeeklyReport.reportTemplate.
  reportTemplate String?
  isLocked       Boolean  @default(false)
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // ── Header (auto-filled, not user-typed) ──
  reportingPeriod String? // e.g. "Mar 1 to Mar 31, 2026"

  // ── Section 1: Executive Summary ──
  executiveSummary String? @db.Text

  // ── Section 2: Production Output ──
  totalVideoTarget                String?
  totalVideoActual                String?
  totalVideoVariance              String?
  heroContentTarget               String?
  heroContentActual               String?
  heroContentVariance             String?
  // Override flags: when true, the actual was manually entered by a CEO/developer and
  // must not be clobbered by auto-recompute. When false, actuals are recomputed from
  // qualified CM Check 4 cases on every GET and persisted on every save.
  totalVideoActualOverridden      Boolean @default(false)
  heroContentActualOverridden     Boolean @default(false)
  // Videos Published: count of cases in the manager's production lists with an
  // uploadDate in the reporting window (day 4 → day 3 next month).
  videosPublishedTarget           String?
  videosPublishedActual           String?
  videosPublishedVariance         String?
  videosPublishedActualOverridden Boolean @default(false)
  // Targets Completed (by Managers) — the manager-entered "what we actually
  // achieved" number, distinct from the ClickUp-derived *Actual count. Sits
  // between Actual ClickUp and Reason in the Section 2 / A Overall Output
  // table; red-highlighted as a manual entry when filled.
  totalVideoTargetAchieved        String?
  heroContentTargetAchieved       String?
  videosPublishedTargetAchieved   String?
  editorNotes                     Json?   @db.JsonB // { [editorId]: "note text" }
  writerNotes                     Json?   @db.JsonB // { [writerId]: "note text" }
  // Manager-added cases that don't appear in the auto-detected list — used
  // when work landed under the wrong owner or was completed offline.
  // Shape: { [userId]: Array<{ id: string, name: string }> }
  editorExtraCases                Json?   @db.JsonB
  writerExtraCases                Json?   @db.JsonB

  // ── Section 3: Shortfall Analysis ──
  shortfallSummary String? @db.Text

  // ── Section 4: Team Recognition ──
  teamRecognition String? @db.Text

  // ── Section 5: Key Learnings ──
  keyLearning1 String? @db.Text
  keyLearning2 String? @db.Text
  keyLearning3 String? @db.Text

  // ── Section 5B: Risks & Immediate Attention ──
  risksAttention String? @db.Text

  // ── Section 6: Behavioral Concerns (Optional & Confidential) ──
  behavioralConcerns String? @db.Text

  // ── Section 7: Remark (Optional) ──
  remark String? @db.Text

  // ── Nishant Bhatia monthly report (researcher format) ──
  nishantResearcherRows Json? @db.JsonB // Array of researcher performance rows
  nishantOverview       Json? @db.JsonB // Monthly overview summary row

  // Andrew James monthly sections
  andrewA1Rows Json? @db.JsonB // Section A1: QA Script review rows (Andrew/Muskan)
  andrewA2Rows Json? @db.JsonB // Section A2: QA Video review rows (Abhishek)
  andrewBRows  Json? @db.JsonB // Section B: Monthly overview rows
  andrewCRows  Json? @db.JsonB // Section C: Rohini & Shika thumbnail rows
  andrewDRows  Json? @db.JsonB // Section D: Views and Changes rows
  andrewERows  Json? @db.JsonB // Section E: Views and Changes (YT Shorts) rows

  // Tanvi Dogra HR Manager monthly report
  hrMonthlyData Json? @db.JsonB // All HR monthly report sections

  /// Frozen team roster at submit/lock time so historical reports
  /// keep showing who was on the team that month even if those users
  /// later move to a different manager. Shape matches WeeklyReport.teamSnapshot.
  /// Null on legacy rows submitted before this column existed — those fall
  /// back to the live `manager.teamMembers` query.
  teamSnapshot Json? @db.JsonB

  manager User @relation("ManagerMonthlyReports", fields: [managerId], references: [id])

  @@unique([managerId, month, year])
  // Template-inclusive identity (Phase A: added alongside the legacy key above).
  @@unique([managerId, reportTemplate, month, year])
  @@index([managerId])
  @@index([year, month]) // covers ORDER BY year desc, month desc
}

model UserReportAccess {
