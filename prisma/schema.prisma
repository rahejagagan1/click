generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  admin
  manager
  lead
  sub_lead
  writer
  editor
  graphic_designer
  qa
  researcher
  gc
  vo_artist
  publisher
  production_manager
  hr_manager
  researcher_manager
  member
}

enum OrgLevel {
  ceo
  special_access
  hod
  manager
  hr_manager
  lead
  sub_lead
  production_team
  member
}

model User {
  id                         Int      @id @default(autoincrement())
  /// Nullable: HR-registered users may not exist in ClickUp yet. Backfilled by sync when a ClickUp user with matching email is found.
  clickupUserId              BigInt?  @unique
  name                       String
  email                      String   @unique
  role                       UserRole @default(member)
  orgLevel                   OrgLevel @default(member)
  /// New designation-based RBAC. Nullable during migration while orgLevel/role
  /// still co-exist; backfilled from (orgLevel, role), then the source of truth.
  designationId              Int?
  managerId                  Int?
  /// Day-to-day / dotted-line manager. Independent of the formal
  /// reporting line in `managerId` — used for org-tree views that need
  /// to show a secondary supervisor (e.g. a team lead who runs the
  /// rituals while the head-of-department signs off).
  inlineManagerId            Int?
  teamCapsule                String?
  /// Monthly case delivery target for CM/PM (denominator for delivery %). Per-manager.
  monthlyDeliveryTargetCases Int?
  isActive                   Boolean  @default(true)
  reportAccess               Boolean  @default(false)
  /// True when the user must walk through the first-login wizard
  /// (/onboarding) before reaching the dashboard. Set by HR at creation
  /// when "Enable onboarding flow" is toggled on.
  onboardingPending          Boolean  @default(false)
  profilePictureUrl          String?
  /// Which LeavePolicy this user is assigned to. Null = no policy (HR
  /// must set balances manually). Used by accrual + "Apply policy" flows.
  leavePolicyId              Int?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  manager       User?        @relation("TeamHierarchy", fields: [managerId], references: [id])
  teamMembers   User[]       @relation("TeamHierarchy")
  inlineManager User?        @relation("InlineHierarchy", fields: [inlineManagerId], references: [id])
  inlineReports User[]       @relation("InlineHierarchy")
  designation   Designation? @relation(fields: [designationId], references: [id])

  assignedCases                  Case[]                          @relation("CaseAssignee")
  researchedCases                Case[]                          @relation("CaseResearcher")
  writtenCases                   Case[]                          @relation("CaseWriter")
  editedCases                    Case[]                          @relation("CaseEditor")
  assignedSubtasks               Subtask[]                       @relation("SubtaskAssignee")
  caseAssignments                CaseAssignee[]
  subtaskAssignments             SubtaskAssignee[]
  caseEditorEntries              CaseEditorEntry[]
  caseWriterEntries              CaseWriterEntry[]
  monthlyRatings                 MonthlyRating[]
  scorecardConfigs               ScorecardConfig[]
  scoreEditsMade                 ScoreEditLog[]                  @relation("ScoreEditor")
  managerRatingsGiven            ManagerRating[]                 @relation("RatingManager")
  managerRatingsReceived         ManagerRating[]                 @relation("RatedUser")
  weeklyReports                  WeeklyReport[]                  @relation("ManagerWeeklyReports")
  monthlyReports                 MonthlyReport[]                 @relation("ManagerMonthlyReports")
  reportViewAccess               UserReportAccess[]              @relation("ReportViewer")
  reportViewableBy               UserReportAccess[]              @relation("ReportViewable")
  designationReportViewable      DesignationReportAccess[]       @relation("DesignationReportViewable")
  violations                     Violation[]                     @relation("ViolationUser")
  violationsReported             Violation[]                     @relation("ViolationReporter")
  violationsResponsible          Violation[]                     @relation("ViolationResponsible")
  violationFilesUploaded         ViolationActionFile[]           @relation("ViolationFileUploader")
  teamRatingsGiven               TeamManagerRating[]             @relation("TeamMemberRater")
  teamRatingsReceived            TeamManagerRating[]             @relation("ManagerRated")
  dashboardFeedbacks             UserFeedback[]
  youtubeDashUserQuarterChannels YoutubeDashUserQuarterChannel[]
  channelViewTargetsUpdated      ChannelViewTarget[]             @relation("ChannelViewTargetUpdater")
  pulseResponses                 PulseResponse[]                 @relation("PulseResponseUser")

  // ── HR Module Relations ──
  employeeProfile              EmployeeProfile?
  attendances                  Attendance[]
  userShift                    UserShift?
  leavePolicy                  LeavePolicy?                 @relation(fields: [leavePolicyId], references: [id])
  leaveBalances                LeaveBalance[]
  leaveApplications            LeaveApplication[]           @relation("LeaveApplicant")
  leaveApprovals               LeaveApplication[]           @relation("LeaveApprover")
  leaveFinalApprovals          LeaveApplication[]           @relation("LeaveFinalApprover")
  leaveCoverages               LeaveApplication[]           @relation("LeavePOC")
  heldAssets                   AssetAssignment[]
  ownedDocuments               EmployeeDocument[]           @relation("DocOwner")
  uploadedDocuments            EmployeeDocument[]           @relation("DocUploader")
  raisedTickets                Ticket[]                     @relation("TicketRaiser")
  assignedTickets              Ticket[]                     @relation("TicketAssignee")
  ticketComments               TicketComment[]
  postedAnnouncements          Announcement[]
  readAnnouncements            AnnouncementRead[]
  goals                        Goal[]
  expenses                     Expense[]
  expensesApproved             Expense[]                    @relation("ExpenseApprover")
  travelRequests               TravelRequest[]
  travelRequestsApproved       TravelRequest[]              @relation("TravelApprover")
  salaryStructure              SalaryStructure?
  payslips                     Payslip[]
  salaryHolds                  SalaryHold[]                 @relation("SalaryHoldUser")
  salaryHoldsCreated           SalaryHold[]                 @relation("SalaryHoldCreator")
  taxOverrides                 TaxOverride[]                @relation("TaxOverrideUser")
  taxOverridesCreated          TaxOverride[]                @relation("TaxOverrideCreator")
  regularizations              AttendanceRegularization[]   @relation("RegularizationUser")
  regularizationsApproved      AttendanceRegularization[]   @relation("RegularizationApprover")
  regularizationsFinalApproved AttendanceRegularization[]   @relation("RegularizationFinalApprover")
  regularizationsGranted       AttendanceRegularization[]   @relation("RegularizationGrantedBy")
  wfhRequests                  WFHRequest[]                 @relation("WFHUser")
  wfhApprovals                 WFHRequest[]                 @relation("WFHApprover")
  wfhCoverages                 WFHRequest[]                 @relation("WFHPOC")
  wfhBalances                  WfhBalance[]                 @relation("WfhBalanceUser")
  wfhBalancesUpdated           WfhBalance[]                 @relation("WfhBalanceUpdater")
  onDutyRequests               OnDutyRequest[]              @relation("OnDutyUser")
  onDutyApprovals              OnDutyRequest[]              @relation("OnDutyApprover")
  onDutyCoverages              OnDutyRequest[]              @relation("OnDutyPOC")
  compOffRequests              CompOffRequest[]             @relation("CompOffUser")
  compOffApprovals             CompOffRequest[]             @relation("CompOffApprover")
  compOffCoverages             CompOffRequest[]             @relation("CompOffPOC")
  engagePosts                  EngagePost[]                 @relation("EngageAuthor")
  engagePraises                EngagePost[]                 @relation("EngagePraiseTo")
  engageReactions              EngageReaction[]
  engageComments               EngageComment[]              @relation("EngageCommentAuthor")
  notifications                Notification[]               @relation("NotificationRecipient")
  notificationsTriggered       Notification[]               @relation("NotificationActor")
  tabPermissions               UserTabPermission[]          @relation("UserTabPermsOwner")
  tabPermissionsUpdated        UserTabPermission[]          @relation("UserTabPermsUpdater")
  notificationPolicy           EmployeeNotificationPolicy?  @relation("NotifPolicyOwner")
  notificationPoliciesUpdated  EmployeeNotificationPolicy[] @relation("NotifPolicyUpdater")
  auditLogs                    AuditLog[]                   @relation("AuditLogActor")
  employeeExit                 EmployeeExit?                @relation("ExitUser")
  exitsInitiated               EmployeeExit[]               @relation("ExitInitiator")
  exitNotesAuthored            ExitNote[]                   @relation("ExitNoteAuthor")
  exitTasksAssigned            ExitTask[]                   @relation("ExitTaskAssignee")
  exitSettlementsFinalised     ExitSettlement[]             @relation("SettlementFinaliser")

  // ── Hiring / ATS relations ──
  jobsAsRecruiter      JobOpening[]              @relation("JobOpeningRecruiter")
  jobsAsHiringManager  JobOpening[]              @relation("JobOpeningHiringManager")
  jobsAsInterviewer    JobOpeningInterviewer[]   @relation("JobOpeningInterviewer")
  // Restored 2026-06-12 — recruiter-pool back-relation for JobOpeningRecruiterJoin.
  jobsInRecruiterPool  JobOpeningRecruiterJoin[] @relation("JobOpeningRecruiterJoinUser")
  // Restored 2026-06-12 — hiring-manager-pool back-relation for JobOpeningHiringManagerJoin.
  jobsInHiringManagerPool JobOpeningHiringManagerJoin[] @relation("JobOpeningHiringManagerJoinUser")
  candidatesReferred   JobApplication[]          @relation("JobApplicationReferrer")
  stageMovesMade       JobApplicationStage[]     @relation("StageMover")
  interviewsAsPanelist InterviewPanelist[]       @relation("InterviewPanelist")
  interviewScorecards  InterviewScorecard[]      @relation("InterviewerScorecard")
  offersCreated        OfferLetter[]             @relation("OfferCreator")
  candidateActivities  CandidateActivity[]       @relation("CandidateActivityActor")

  // ── KPI document uploads ──
  kpiDocumentsUploaded KpiDocument[] @relation("KpiDocumentUploader")

  // ── WFH Policy (singleton updater) ──
  wfhPolicyUpdates WfhPolicy[] @relation("WfhPolicyUpdater")

  // ── HR dropdown option lists (restored 2026-06-12) ──
  optionListsCreated OptionList[] @relation("OptionListCreator")

  // ── Adhoc payroll line items (restored 2026-06-12) ──
  adhocLineItems        AdhocLineItem[] @relation("AdhocLineItemUser")
  adhocLineItemsCreated AdhocLineItem[] @relation("AdhocLineItemCreator")

  // ── One-time bonus / perk payouts (restored 2026-06-12) ──
  bonuses        EmployeeBonus[] @relation("EmployeeBonusUser")
  bonusesCreated EmployeeBonus[] @relation("EmployeeBonusCreator")

  // ── Legacy candidate-stage history (restored 2026-06-12) ──
  candidateStageMoves CandidateStage[] @relation("CandidateStageMover")

  @@index([managerId])
  @@index([inlineManagerId])
  @@index([designationId])
}

// ═══════════════════════════════════════════════════════
// RBAC — designation-based permissions (replaces orgLevel/role)
//
// Permission keys are code-defined (src/lib/permissions/catalog.ts) and seeded
// into `Permission` so the HR-Manager admin UI can list/describe them. The
// GRANTS (DesignationPermission) are editable at runtime. User.designationId
// points at the holder's designation, whose permissions resolve via `can()`.
// ═══════════════════════════════════════════════════════

model Permission {
  id          Int      @id @default(autoincrement())
  /// Matches a Permission literal in src/lib/permissions/catalog.ts.
  key         String   @unique
  label       String
  description String?
  category    String
  sensitive   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designations DesignationPermission[]
}

model Designation {
  id                Int      @id @default(autoincrement())
  /// Stable slug used in code/seed (e.g. "hr_manager", "video_editor").
  key               String   @unique
  /// Human-facing title shown in the UI (e.g. "HR Manager").
  label             String
  /// Optional rating track for the scorecard engine. Null = not rated by a
  /// production scorecard. One of: writer|editor|qa|researcher|manager.
  scorecardFunction String?
  /// Brand the designation belongs to ("NB Media" | "YT Labs"). Each brand
  /// shows only its own designations in the admin UI; clone copies across.
  businessUnit      String?  @default("NB Media")
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  /// System designations are seeded to mirror legacy access. HR can edit them
  /// but the UI blocks deletion so a built-in tier can't be removed by mistake.
  isSystem          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  permissions          DesignationPermission[]
  reportAccessGrants   DesignationReportAccess[]
  reportTemplateGrants DesignationReportTemplate[]
  users                User[]
}

model DesignationPermission {
  designationId Int
  permissionId  Int
  /// Audit trail: who granted this permission to this designation, and when.
  grantedBy     Int?
  createdAt     DateTime @default(now())

  designation Designation @relation(fields: [designationId], references: [id], onDelete: Cascade)
  permission  Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([designationId, permissionId])
  @@index([permissionId])
}

// Per-designation grant to VIEW a report-owner's (manager's) weekly/monthly
// reports. The designation-level replacement for per-user UserReportAccess:
// every member of the designation can view the granted owners' reports.
// Enforcement unions these with any legacy UserReportAccess rows.
model DesignationReportAccess {
  designationId Int
  managerId     Int // report-owner User id
  /// Audit trail: who granted this, and when.
  grantedBy     Int?
  createdAt     DateTime @default(now())

  designation Designation @relation(fields: [designationId], references: [id], onDelete: Cascade)
  manager     User        @relation("DesignationReportViewable", fields: [managerId], references: [id], onDelete: Cascade)

  @@id([designationId, managerId])
  @@index([managerId])
}

// Which report templates a designation fills + can view (production|researcher|
// qa|hr). Multiple per designation. Replaces the hardcoded name/role logic that
// used to decide who fills which report — whoever holds the designation fills
// (and views) its templates going forward.
model DesignationReportTemplate {
  designationId Int
  template      String // 'production' | 'researcher' | 'qa' | 'hr'
  /// Audit trail: who granted this, and when.
  grantedBy     Int?
  createdAt     DateTime @default(now())

  designation Designation @relation(fields: [designationId], references: [id], onDelete: Cascade)

  @@id([designationId, template])
  @@index([template])
}

// ═══════════════════════════════════════════════════════
// Dashboard product feedback (any authenticated user)
// ═══════════════════════════════════════════════════════

model UserFeedback {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String   @default("general_issue")
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Space {
  id             Int      @id @default(autoincrement())
  clickupSpaceId String   @unique
  name           String
  isSynced       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  capsules Capsule[]
}

model Capsule {
  id              Int      @id @default(autoincrement())
  clickupFolderId String   @unique
  spaceId         Int
  name            String
  shortName       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  space           Space            @relation(fields: [spaceId], references: [id])
  productionLists ProductionList[]
}

model ProductionList {
  id            Int      @id @default(autoincrement())
  clickupListId String   @unique
  capsuleId     Int?
  spaceId       Int?
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  capsule Capsule? @relation(fields: [capsuleId], references: [id])
  cases   Case[]
}

model Case {
  id               Int     @id @default(autoincrement())
  clickupTaskId    String  @unique
  productionListId Int
  name             String
  status           String
  statusType       String?
  clickupUrl       String?

  assigneeUserId   Int?
  researcherUserId Int?
  writerUserId     Int?
  editorUserId     Int?

  caseRating Decimal? @db.Decimal(3, 1)
  caseType   String?
  channel    String?

  tthDocLink           String?
  title                String? @db.Text
  scriptFirstDraftLink String?
  finalScriptLink      String?
  voDocLink            String?
  voLink               String?
  videoFirstDraftLink  String?
  finalVideoLink       String?

  scriptQaStartDate     DateTime?
  writerQualityScore    Int?
  writerDeliveryTime    String?
  writerEfficiencyScore String?
  finalWriterRating     Decimal?  @db.Decimal(5, 2)
  scriptQualityRating   Decimal?  @db.Decimal(4, 2)
  scriptRatingReason    String?   @db.Text

  videoGcStartDate      DateTime?
  videoChangesCount     Int?
  qaVideoMeetingDate    DateTime?
  editorQualityScore    Int?
  editorDeliveryTime    String?
  editorEfficiencyScore String?
  finalVideoRating      Decimal?  @db.Decimal(5, 2)
  videoQualityRating    Decimal?  @db.Decimal(4, 2)
  videoRatingReason     String?   @db.Text

  helperEditorE Int?
  helperEditorT Int?
  helperWriterE Int?
  helperWriterT Int?

  uploadDate         DateTime?
  caseStartDate      DateTime?
  caseCompletionDate DateTime?
  overallTat         Decimal?  @db.Decimal(5, 1)
  tat                Decimal?  @db.Decimal(5, 1)
  youtubeVideoUrl    String?

  dateCreated     DateTime?
  dateDone        DateTime?
  lastSyncedAt    DateTime  @default(now())
  isArchived      Boolean   @default(false)
  /// Set by the sync when a level-3+ subtask (sub-subtask) is detected anywhere
  /// under this case. Our schema only models Case → Subtask; anything deeper
  /// can't be stored, so we surface the case for manual cleanup in ClickUp.
  hasDeepSubtasks Boolean   @default(false)

  productionList ProductionList    @relation(fields: [productionListId], references: [id])
  assignee       User?             @relation("CaseAssignee", fields: [assigneeUserId], references: [id])
  researcher     User?             @relation("CaseResearcher", fields: [researcherUserId], references: [id])
  writer         User?             @relation("CaseWriter", fields: [writerUserId], references: [id])
  editor         User?             @relation("CaseEditor", fields: [editorUserId], references: [id])
  subtasks       Subtask[]
  assignees      CaseAssignee[]
  allEditors     CaseEditorEntry[]
  allWriters     CaseWriterEntry[]
  youtubeStats   YoutubeStats?

  @@index([status])
  @@index([statusType])
  @@index([channel])
  @@index([writerUserId])
  @@index([editorUserId])
  @@index([assigneeUserId])
  @@index([researcherUserId])
  @@index([productionListId])
  @@index([dateCreated])
}

model CaseAssignee {
  id            Int    @id @default(autoincrement())
  caseId        Int
  userId        Int
  clickupUserId BigInt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@index([caseId])
  @@index([userId])
}

model CaseEditorEntry {
  id            Int     @id @default(autoincrement())
  caseId        Int
  userId        Int
  clickupUserId BigInt?
  case          Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@index([caseId])
}

model CaseWriterEntry {
  id            Int     @id @default(autoincrement())
  caseId        Int
  userId        Int
  clickupUserId BigInt?
  case          Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@index([caseId])
}

model Subtask {
  id               Int       @id @default(autoincrement())
  clickupTaskId    String    @unique
  caseId           Int
  name             String
  status           String
  statusType       String?
  assigneeUserId   Int?
  startDate        DateTime?
  dueDate          DateTime?
  dateDone         DateTime?
  orderIndex       Int?
  tat              Decimal?  @db.Decimal(7, 2)
  customFieldsJson Json?     @db.JsonB
  dateCreated      DateTime?
  lastSyncedAt     DateTime  @default(now())

  case      Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignee  User?             @relation("SubtaskAssignee", fields: [assigneeUserId], references: [id])
  assignees SubtaskAssignee[]

  @@index([caseId])
  @@index([assigneeUserId])
}

model SubtaskAssignee {
  id            Int    @id @default(autoincrement())
  subtaskId     Int
  userId        Int
  clickupUserId BigInt

  subtask Subtask @relation(fields: [subtaskId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([subtaskId, userId])
  @@index([subtaskId])
  @@index([userId])
}

model YoutubeStats {
  id              Int       @id @default(autoincrement())
  caseId          Int       @unique
  youtubeVideoId  String
  videoUrl        String
  videoTitle      String?
  viewCount       BigInt?
  likeCount       BigInt?
  commentCount    BigInt?
  last30DaysViews BigInt?
  publishedAt     DateTime?
  lastFetchedAt   DateTime  @default(now())

  case    Case                  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  history YoutubeStatsHistory[]

  @@index([youtubeVideoId])
}

model YoutubeStatsHistory {
  id             Int      @id @default(autoincrement())
  youtubeStatsId Int
  snapshotDate   DateTime @db.Date
  viewCount      BigInt
  likeCount      BigInt?

  youtubeStats YoutubeStats @relation(fields: [youtubeStatsId], references: [id], onDelete: Cascade)

  @@unique([youtubeStatsId, snapshotDate])
}

model MonthlyRating {
  id                 Int      @id @default(autoincrement())
  userId             Int
  month              DateTime @db.Date
  roleType           String
  casesCompleted     Int      @default(0)
  avgQualityScore    Decimal? @db.Decimal(5, 2)
  avgDeliveryScore   Decimal? @db.Decimal(5, 2)
  avgEfficiencyScore Decimal? @db.Decimal(5, 2)
  totalViews         BigInt?
  overallRating      Decimal? @db.Decimal(5, 2)
  rankInRole         Int?
  isManualOverride   Boolean  @default(false)
  calculatedAt       DateTime @default(now())

  // Per-parameter star ratings (1-5)
  // Note: writerQualityStars / scriptQualityStars are kept for backward compat.
  // For editors these map to editorQuality / videoQuality respectively.
  // parametersJson is the authoritative breakdown — named columns are convenience only.
  writerQualityStars   Decimal? @db.Decimal(3, 1)
  scriptQualityStars   Decimal? @db.Decimal(3, 1)
  ownershipStars       Decimal? @db.Decimal(3, 1)
  monthlyTargetsStars  Decimal? @db.Decimal(3, 1)
  ytViewsStars         Decimal? @db.Decimal(3, 1)
  parametersJson       Json?    @db.JsonB // full calculation breakdown (authoritative)
  manualRatingsPending Boolean  @default(true)

  // Formula versioning — which template produced this result
  formulaTemplateId Int?
  formulaVersion    Int?

  user            User             @relation(fields: [userId], references: [id])
  editLogs        ScoreEditLog[]
  formulaTemplate FormulaTemplate? @relation(fields: [formulaTemplateId], references: [id])

  @@unique([userId, month, roleType])
  @@index([month])
}

model SyncLog {
  id            Int       @id @default(autoincrement())
  syncType      String
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  recordsSynced Int?
  errorsCount   Int?      @default(0)
  errorDetails  Json?     @db.JsonB
  status        String    @default("running")

  @@index([syncType, status, completedAt]) // covers sync-status query
  @@index([startedAt]) // covers dashboard lastSync query
}

model SyncConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique // e.g. "selected_spaces", "selected_lists"
  value     Json     @db.JsonB
  updatedAt DateTime @updatedAt
}

model YtVideoLookup {
  id             Int       @id @default(autoincrement())
  youtubeVideoId String    @unique
  videoUrl       String
  title          String
  viewCount      BigInt
  likeCount      BigInt?
  commentCount   BigInt?
  publishedAt    DateTime?
  fetchedAt      DateTime  @default(now())
}

/// YouTube dashboard: videos published on/after YT_DASHBOARD_PUBLISHED_SINCE, refreshed on cron (e.g. every 5h).
model YoutubeDashboardVideo {
  id             Int       @id @default(autoincrement())
  youtubeVideoId String    @unique
  channelId      String
  channelName    String
  title          String
  publishedAt    DateTime?
  viewCount      BigInt
  likeCount      BigInt?
  syncedAt       DateTime  @default(now())

  @@index([channelId])
  @@index([publishedAt])
  @@index([syncedAt])
}

/// YouTube dashboard: per-channel quarter view totals from YouTube Analytics (refreshed on manual / cron sync).
model YoutubeDashboardQuarterMetrics {
  id                   Int      @id @default(autoincrement())
  channelId            String
  year                 Int
  quarter              Int
  analyticsStartStr    String
  analyticsEndStr      String
  viewsGainedInQuarter BigInt?
  fetchedAt            DateTime @default(now()) @updatedAt

  @@unique([channelId, year, quarter])
  @@index([year, quarter])
}

model ChannelViewTarget {
  id          Int      @id @default(autoincrement())
  /// YouTube channel id (e.g. "UCjRdMPERN1T0LwAtnshS9UQ"). Matches YOUTUBE_CHANNELS env.
  channelId   String
  /// Display name cached at write time so the UI does not need to re-resolve from env.
  channelName String
  year        Int
  /// 0 = year-level target. 1-4 = quarter target. One row per (channelId, year, quarter).
  quarter     Int
  /// Target view count. BigInt so 10M+ figures survive serialisation.
  target      BigInt
  updatedAt   DateTime @updatedAt
  /// HR-admin who last set this. Null for legacy / seed rows.
  updatedById Int?
  updatedBy   User?    @relation("ChannelViewTargetUpdater", fields: [updatedById], references: [id])

  @@unique([channelId, year, quarter])
  @@index([year, quarter])
}

/// YouTube dashboard: per-channel 10-day bucket chart + uploads (filled on same cron as quarter metrics).
model YoutubeDashboardChannelQuarterAnalysis {
  id            Int      @id @default(autoincrement())
  channelId     String
  year          Int
  quarter       Int
  /// { analyticsStartStr, analyticsEndStr, buckets: [...], uploadsTotal }
  chartJson     Json     @db.JsonB
  headlineViews Int?
  fetchedAt     DateTime @default(now()) @updatedAt

  @@unique([channelId, year, quarter])
  @@index([year, quarter])
}

/// ClickUp users whose email does not match any HR User. Populated by the sync job.
